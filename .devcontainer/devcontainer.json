{
  "name": "Yocto PPE Workspace",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "yocto",
  "workspaceFolder": "/home/yocto/ws/yocto-ppe-workspace",

  "remoteUser": "yocto",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.remote-containers"
      ]
    }
  },


  "containerEnv": {
    "BB_NUMBER_THREADS": "3",
    "PARALLEL_MAKE": "-j2"
  }
}
