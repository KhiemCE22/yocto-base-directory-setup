{
  "name": "Yocto PPE Workspace",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "yocto",
  "workspaceFolder": "/workspaces/yocto-ppe-workspace",
  "remoteUser": "yocto",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.remote-containers"
      ]
    }
  },
  "postCreateCommand": "git config --global --add safe.directory /workspaces/yocto-ppe-workspace",
  "mounts": [
    "source=${localWorkspaceFolder}/downloads,target=/downloads,type=bind",
    "source=${localWorkspaceFolder}/sstate-cache,target=/sstate-cache,type=bind"
  ],
  "containerEnv": {
    "DL_DIR": "/downloads",
    "SSTATE_DIR": "/sstate-cache",
    "BB_NUMBER_THREADS": "8",
    "PARALLEL_MAKE": "-j8"
  }
}
